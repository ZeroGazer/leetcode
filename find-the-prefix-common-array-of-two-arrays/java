class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int[] results = new int[A.length];
        int[] freqs = new int[A.length + 1];
        int count = 0;
        for (int i = 0; i < results.length; i++) {
            if (++freqs[A[i]] > 1) {
                count++;
            }
            if (++freqs[B[i]] > 1) {
                count++;
            }
            results[i] = count;
        }
        return results;
    }
}