class Solution {
    public char findKthBit(int n, int k) {
        if (n == 1) {
            return '0';
        }
        int length = 1 << n;
        if (k < length / 2) {
            return findKthBit(n - 1, k);
        } else if (k == length / 2) {
            return '1';
        } else {
            return findKthBit(n - 1, length - k) == '0' ? '1' : '0';
        }
    }
}