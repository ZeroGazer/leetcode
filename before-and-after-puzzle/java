class Solution {
    public List<String> beforeAndAfterPuzzles(String[] phrases) {
        Map<String, List<String>> map = new HashMap<>();
        for (String phrase : phrases) {
            String key = phrase;
            int firstSpaceIndex = phrase.indexOf(" ");
            if (firstSpaceIndex > -1) {
                key = phrase.substring(0, firstSpaceIndex);
            }
            if (!map.containsKey(key)) {
                map.put(key, new ArrayList<>());
            }
            map.get(key).add(phrase);
        }
        Set<String> set = new HashSet<>();
        for (Map.Entry<String, List<String>> e : map.entrySet()) {
            for (String phrase : e.getValue()) {
                String lastWord = phrase;
                int lastSpaceIndex = phrase.lastIndexOf(" ");
                if (lastSpaceIndex > -1) {
                    lastWord = phrase.substring(lastSpaceIndex + 1);
                }
                if (map.containsKey(lastWord)) {
                    boolean hasSame = false;
                    for (String second : map.get(lastWord)) {
                        if (phrase.equals(second) && !hasSame) {
                            hasSame = true;
                            continue;
                        }
                        int firstSpaceIndex = second.indexOf(" ");
                        if (firstSpaceIndex > -1) {
                            set.add(phrase + second.substring(firstSpaceIndex));
                        } else {
                            set.add(phrase);
                        }
                    }
                }
            }
        }
        List<String> result = new ArrayList<>(set);
        Collections.sort(result);
        return result;
    }
}