class Solution {
    public int[] avoidFlood(int[] rains) {
        int n = rains.length;
        int[] result = new int[n];
        Arrays.fill(result, 1);
        TreeSet<Integer> drySet = new TreeSet<Integer>();
        Map<Integer, Integer> rainMap = new HashMap<Integer, Integer>();
        for (int i = 0; i < n; i++) {
            if (rains[i] == 0) {
                drySet.add(i);
            } else {
                result[i] = -1;
                if (rainMap.containsKey(rains[i])) {
                    Integer dryDay = drySet.ceiling(rainMap.get(rains[i]));
                    if (dryDay == null) {
                        return new int[0];
                    }
                    result[dryDay] = rains[i];
                    drySet.remove(dryDay);
                }
                rainMap.put(rains[i], i);
            }
        }
        return result;
    }
}