class Solution {
    public int longestNiceSubarray(int[] nums) {
        int bit = 0, max = 0;
        for (int left = 0, right = 0; right < nums.length; right++) {
            while ((bit & nums[right]) > 0) {
                bit ^= nums[left++];
            }
            bit |= nums[right];
            max = Math.max(max, right - left + 1);
        }
        return max;
    }
}