class Solution {
    public String makeFancyString(String s) {
        StringBuilder sb = new StringBuilder();
        int count = 0;
        for (char c : s.toCharArray()) {
            if (!sb.isEmpty() && sb.charAt(sb.length() - 1) == c) {
                if (count != 2) {
                    sb.append(c);
                    count++;
                }
            } else {
                sb.append(c);
                count = 1;
            }
        }
        return sb.toString();
    }
}