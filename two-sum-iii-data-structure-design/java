class TwoSum {
    
    private Map<Integer, Integer> freqs = new HashMap<>();

    public TwoSum() {
        
    }
    
    public void add(int number) {
        freqs.put(number, freqs.getOrDefault(number, 0) + 1);
    }
    
    public boolean find(int value) {
        for (Map.Entry<Integer, Integer> e : freqs.entrySet()) {
            int pair = value - e.getKey();
            if (freqs.containsKey(pair)) {
                if (pair == e.getKey()) {
                    if (e.getValue() > 1) {
                        return true;
                    }
                } else {
                    return true;
                }
            }
        }
        return false;
    }
}

