class Solution {
    private int[][] DIRECTIONS = {{0, 1}, {0, -1}, {1, 0}, {-1, 0}};

    public int minCost(int[][] grid) {
        int[][] costs = new int[grid.length][grid[0].length];
        for (int[] is : costs) {
            Arrays.fill(is, Integer.MAX_VALUE);
        }
        costs[0][0] = 0;
        Queue<int[]> queue = new PriorityQueue<>(Comparator.comparingInt(x -> x[2]));
        queue.add(new int[] {0, 0, 0});
        while (!queue.isEmpty()) {
            int[] curr = queue.poll();
            if (costs[curr[0]][curr[1]] > curr[2]) {
                continue;
            }
            for (int i = 0; i < DIRECTIONS.length; i++) {
                int x = curr[0] + DIRECTIONS[i][0], y = curr[1] + DIRECTIONS[i][1];
                if (x > -1 && x < grid.length && y > -1 && y < grid[0].length) {
                    int newCost = curr[2] + (i + 1 == grid[curr[0]][curr[1]] ? 0 : 1);
                    if (costs[x][y] > newCost) {
                        costs[x][y] = newCost;
                        queue.add(new int[] {x, y, newCost});
                    }
                }
            }
        }
        return costs[grid.length - 1][grid[0].length - 1];
    }
}