class Solution {
    public String largestGoodInteger(String num) {
        String result = "";
        for (int i = 2; i < num.length(); i++) {
            if (num.charAt(i - 2) == num.charAt(i) && num.charAt(i - 1) == num.charAt(i)) {
                if (result.isEmpty() || result.charAt(0) < num.charAt(i)) {
                    result = "" + num.charAt(i - 2) + num.charAt(i - 1) + num.charAt(i);
                }
            }
        }
        return result;
    }
}