class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int max = 0, count0 = 0;
        for (int p = 0, q = 0; q < nums.length; q++) {
            if (nums[q] == 0) {
                count0++;
            }
            while (count0 > 1) {
                if (nums[p++] == 0) {
                    count0--;
                }
            }
            max = Math.max(max, q - p + 1);
        }
        return max;
    }
}