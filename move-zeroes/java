class Solution {
    public void moveZeroes(int[] nums) {
        int n = nums.length, zeros = 0;
        for (int left = 0, right = 0; right < n; right++) {
            if (nums[right] == 0) {
                zeros++;
            } else {
                nums[left++] = nums[right];
            }
        }
        for (int i = 0; i < zeros; i++) {
            nums[n - 1 - i] = 0;
        }
    }
}