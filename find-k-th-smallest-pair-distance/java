class Solution {
    public int smallestDistancePair(int[] nums, int k) {
        int n = nums.length;
        Arrays.sort(nums);
        int left = 0, right = nums[n - 1] - nums[0];
        while (left < right) {
            int middle = left + (right - left) / 2;
            if (countPair(nums, n, middle) >= k) {
                right = middle;
            } else {
                left = middle + 1;
            }
        }
        return left;
    }
    
    private int countPair(int[] nums, int n, int x) {
        int count = 0;
        for (int left = 0, right = 0; right < n; right++) {
            while (nums[right] - nums[left] > x) {
                left++;
            }
            count += right - left;
        }
        return count;
    }
}