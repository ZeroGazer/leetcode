class Solution {
    public int minCost(String colors, int[] neededTime) {
        int n = colors.length(), time = 0;
        for (int i = 0, j = 1; i < n && j < n; j++) {
            int max = neededTime[i], sum = neededTime[i];
            while (j < n && colors.charAt(j) == colors.charAt(i)) {
                max = Math.max(max, neededTime[j]);
                sum += neededTime[j++];
            }
            time += sum - max;
            i = j;
        }
        return time;
    }
}