class Solution {
    public boolean isTrionic(int[] nums) {
        int n = nums.length, i = 1;
        while (i < n && nums[i] > nums[i - 1]) {
            i++;
        }
        int p = i - 1;
        while (i < n && nums[i] < nums[i - 1]) {
            i++;
        }
        int q = i - 1;
        while (i < n && nums[i] > nums[i - 1]) {
            i++;
        }
        return (p != 0) && (q != p) && (i != (q + 1)) && (i == n);
    }
}