/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public TreeNode replaceValueInTree(TreeNode root) {
        List<Integer> sumList = new ArrayList<>();
        Queue<TreeNode> queue = new LinkedList<>();
        queue.add(root);
        while (!queue.isEmpty()) {
            int size = queue.size();
            int sum = 0;
            for (int i = 0; i < size; i++) {
                TreeNode curr = queue.poll();
                sum += curr.val;
                if (curr.left != null) {
                    queue.add(curr.left);
                }
                if (curr.right != null) {
                    queue.add(curr.right);
                }
            }
            sumList.add(sum);
        }
        root.val = 0;
        dfs(sumList, root, 0, 0);
        return root;
    }

    private void dfs(List<Integer> sumList, TreeNode root, int level, int cousins) {
        if (root == null) {
            return;
        }
        root.val = cousins;
        if (sumList.size() > level + 1) {
            int children = 0;
            if (root.left != null) {
                children += root.left.val;
            }
            if (root.right != null) {
                children += root.right.val;
            }
            dfs(sumList, root.left, level + 1, sumList.get(level + 1) - children);
            dfs(sumList, root.right, level + 1, sumList.get(level + 1) - children);
        }
    }
}