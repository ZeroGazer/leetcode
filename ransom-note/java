class Solution {
    public boolean canConstruct(String ransomNote, String magazine) {
        int[] freqs1 = new int[26], freqs2 = new int[26];
        for (char c : ransomNote.toCharArray()) {
            freqs1[c - 'a']++;
        }
        for (char c : magazine.toCharArray()) {
            freqs2[c - 'a']++;
        }
        for (int i = 0; i < 26; i++) {
            if (freqs1[i] > freqs2[i]) {
                return false;
            }
        }
        return true;
    }
}