class Solution {
    public int binaryGap(int n) {
        int max = 0;
        for (int i = 0, prev = -1; i < 32; i++) {
            if (((n >> i) & 1) == 1) {
                if (prev > -1) {
                    max = Math.max(max, i - prev);
                }
                prev = i;
            }
        }
        return max;
    }
}