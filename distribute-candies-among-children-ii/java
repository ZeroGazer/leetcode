class Solution {
    public long distributeCandies(int n, int limit) {
        return nC2(n + 2) - (nC2(n - limit + 1) * 3 - nC2(n - (limit + 1) * 2 + 2) * 3 + nC2(n - (limit + 1) * 3 + 2));
    }

    private long nC2(long a) {
        if (a < 2) {
            return 0;
        }
        return a * (a - 1) / 2;
    }
}