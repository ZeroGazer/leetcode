class Solution {
    public boolean checkStrings(String s1, String s2) {
        if (s1.length() != s2.length()) {
            return false;
        }
        int[][] freq = new int[4][26];
        for (int i = 0; i < s1.length(); i++) {
            freq[(i & 1)][s1.charAt(i) - 'a']++;
            freq[(i & 1) + 2][s2.charAt(i) - 'a']++;
        }
        return Arrays.equals(freq[0], freq[2]) & Arrays.equals(freq[1], freq[3]);
    }
}