class Router {

    private int memoryLimit;
    private LinkedHashSet<List<Integer>> set = new LinkedHashSet<>();
    private Map<Integer, List<Integer>> count = new HashMap<>();

    public Router(int memoryLimit) {
        this.memoryLimit = memoryLimit;
    }
    
    public boolean addPacket(int source, int destination, int timestamp) {
        List<Integer> packet = List.of(source, destination, timestamp);
        if (set.contains(packet)) {
            return false;
        }
        if (set.size() == memoryLimit) {
            count.get(set.getFirst().get(1)).removeFirst();
            set.removeFirst();
        }
        set.add(packet);
        count.putIfAbsent(destination, new ArrayList<>());
        count.get(destination).add(timestamp);
        return true;
    }
    
    public int[] forwardPacket() {
        if (set.isEmpty()) {
            return new int[0];
        }
        count.get(set.getFirst().get(1)).removeFirst();
        return set.removeFirst().stream().mapToInt(Integer::intValue).toArray();
    }
    
    public int getCount(int destination, int startTime, int endTime) {
        return count(destination, endTime) - count(destination, startTime - 1);
    }

    private int count(int destination, int time) {
        if (!count.containsKey(destination)) {
            return 0;
        }
        List<Integer> list = count.get(destination);
        int left = 0, right = list.size();
        while (left < right) {
            int middle = left + (right - left) / 2;
            if (list.get(middle) <= time) {
                left = middle + 1;
            } else {
                right = middle;
            }
        }
        return left;
    }
}

