class Solution {
    public long numberOfPowerfulInt(long start, long finish, int limit, String s) {
        return countSmallerThan(Long.toString(finish), limit, s) - countSmallerThan(Long.toString(start - 1), limit, s);
    }

    private long countSmallerThan(String target, int limit, String s) {
        if (target.length() < s.length()) {
            return 0;
        } else if (target.length() == s.length()) {
            return s.compareTo(target) <= 0 ? 1 : 0;
        }
        int prefixLength = target.length() - s.length();
        long count = 0;
        for (int i = 0; i < prefixLength; i++) {
            int digit = target.charAt(i) - '0';
            if (digit > limit) {
                return count + (long) Math.pow(limit + 1, prefixLength - i);
            }
            count += digit * (long) Math.pow(limit + 1, prefixLength - 1 - i);
        }
        if (s.compareTo(target.substring(prefixLength)) <= 0) {
            count++;
        }
        return count;
    }
}