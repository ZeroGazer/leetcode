class Solution {
    public int maxScoreSightseeingPair(int[] values) {
        int maxLeft = values[0], max = values[1] - 1;
        for (int i = 1; i < values.length; i++) {
            max = Math.max(max, maxLeft + values[i] - i);
            maxLeft = Math.max(maxLeft, values[i] + i);
        }
        return max;
    }
}