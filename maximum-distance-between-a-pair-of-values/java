class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
        int n = nums1.length, m = nums2.length, i = 0, j = 1;
        while (i < n && j < m) {
            if (nums1[i] > nums2[j]) {
                i++;
            }
            j++;
        }
        return j - i - 1;
    }
}