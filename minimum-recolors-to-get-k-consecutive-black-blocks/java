class Solution {
    public int minimumRecolors(String blocks, int k) {
        int w = 0, min = Integer.MAX_VALUE;
        for (int i = 0; i < blocks.length(); i++) {
            if (blocks.charAt(i) == 'W') {
                w++;
            }
            if (i + 1 >= k) {
                min = Math.min(min, w);
                if (blocks.charAt(i + 1 - k) == 'W') {
                    w--;
                }
            }
        }
        return min;
    }
}