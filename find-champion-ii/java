class Solution {
    public int findChampion(int n, int[][] edges) {
        int[] indegrees = new int[n];
        for (int[] edge : edges) {
            indegrees[edge[1]]++;
        }
        int champion = 0, championCount = 0;
        for (int i = 0; i < indegrees.length; i++) {
            if (indegrees[i] == 0) {
                champion = i;
                championCount++;
            }
        }
        return championCount == 1 ? champion : -1;
    }
}