class Solution {
    public long minimumTotalDistance(List<Integer> robot, int[][] factory) {
        Collections.sort(robot);
        Arrays.sort(factory, Comparator.comparingInt(e -> e[0]));
        List<Integer> factories = new ArrayList<>();
        for (int[] f : factory) {
            for (int i = 0; i < f[1]; i++) {
                factories.add(f[0]);
            }
        }
        return backtracking(0, 0, robot, factories, new Long[robot.size()][factories.size()]);
    }
    
    private long backtracking(int robot, int factory, List<Integer> robots, List<Integer> factories, Long[][] memo) {
        if (robot == robots.size()) {
            return 0;
        }
        if (factory == factories.size()) {
            return (long) 1e12;
        }
        if (memo[robot][factory] != null) {
            return memo[robot][factory];
        }
        return memo[robot][factory] = Math.min(
            Math.abs(robots.get(robot) - factories.get(factory)) + backtracking(robot + 1, factory + 1, robots, factories, memo),
            backtracking(robot, factory + 1, robots, factories, memo)
        );
    }
}