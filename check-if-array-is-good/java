class Solution {
    public boolean isGood(int[] nums) {
        int n = nums.length;
        int[] freqs = new int[n];
        for (int num : nums) {
            if (num >= n || (num < (n - 1) && freqs[num] > 0) || (num == (n - 1) && freqs[num] > 1)) {
                return false;
            }
            freqs[num]++;
        }
        return true;
    }
}