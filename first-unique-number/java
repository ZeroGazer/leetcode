class FirstUnique {

    private LinkedHashSet<Integer> unique = new LinkedHashSet<>();
    private Set<Integer> duplicate = new HashSet<>();

    public FirstUnique(int[] nums) {
        for (int i : nums) {
            add(i);
        }
    }
    
    public int showFirstUnique() {
        if (unique.isEmpty()) {
            return -1;
        }
        return unique.getFirst();
    }
    
    public void add(int value) {
        if (!duplicate.contains(value)) {
            if (unique.contains(value)) {
                unique.remove(value);
                duplicate.add(value);
            } else {
                unique.add(value);
            }
        }
    }
}

