class Solution {
    public boolean kLengthApart(int[] nums, int k) {
        for (int i = 0, count = k; i < nums.length; i++) {
            if (nums[i] == 0) {
                count++;
            } else if (count < k) {
                return false;
            } else {
                count = 0;
            }
        }
        return true;
    }
}