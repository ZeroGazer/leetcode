class Solution {
    public long maximumHappinessSum(int[] happiness, int k) {
        int n = happiness.length;
        Arrays.sort(happiness);
        long sum = 0;
        for (int i = 0; i < k; i++) {
            if (happiness[n - 1 - i] - i <= 0) {
                break;
            }
            sum += happiness[n - 1 - i] - i;
        }
        return sum;
    }
}