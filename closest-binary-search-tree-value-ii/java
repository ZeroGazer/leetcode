/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public List<Integer> closestKValues(TreeNode root, double target, int k) {
        Queue<Integer> pq = new PriorityQueue<>((x, y) -> Double.compare(Math.abs(y - target), Math.abs(x - target)));
        dfs(root, k, pq);
        return pq.stream().toList();
    }

    private void dfs(TreeNode root, int k, Queue<Integer> pq) {
        if (root == null) {
            return;
        }
        pq.add(root.val);
        if (pq.size() > k) {
            pq.poll();
        }
        dfs(root.left, k, pq);
        dfs(root.right, k, pq);
    }
}