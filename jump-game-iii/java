class Solution {
    public boolean canReach(int[] arr, int start) {
        int n = arr.length;
        Queue<Integer> queue = new LinkedList<>();
        queue.offer(start);
        boolean[] visited = new boolean[n];
        while (!queue.isEmpty()) {
            int curr = queue.poll();
            if (visited[curr]) {
                continue;
            }
            if (arr[curr] == 0) {
                return true;
            }
            visited[curr] = true;
            if (curr - arr[curr] > -1) {
                queue.offer(curr - arr[curr]);
            }
            if (curr + arr[curr] < n) {
                queue.offer(curr + arr[curr]);
            }
        }
        return false;
    }
}