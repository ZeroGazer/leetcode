class Solution {
    public int[] minBitwiseArray(List<Integer> nums) {
        int n = nums.size();
        int[] result = new int[n];
        for (int i = 0; i < n; i++) {
            result[i] = -1;
            int num = nums.get(i), candidate = 1;
            while ((num & candidate) != 0) {
                result[i] = num - candidate;
                candidate <<= 1;
            }
        }
        return result;
    }
}