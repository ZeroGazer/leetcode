class Solution {
    public boolean canConstruct(String s, int k) {
        if (s.length() < k) {
            return false;
        }
        int[] freqs = new int[26];
        for (char c : s.toCharArray()) {
            freqs[c - 'a']++;
        }
        int odd = 0;
        for (int freq : freqs) {
            if (freq % 2 == 1) {
                odd++;
            }
        }
        return odd <= k;
    }
}