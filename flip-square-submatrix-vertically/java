class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        for (int i = y; i < y + k; i++) {
            for (int j = 0; j < k / 2; j++) {
                int temp = grid[j + x][i];
                grid[j + x][i] = grid[x - 1 + k - j][i];
                grid[x - 1 + k - j][i] = temp;
            }
        }
        return grid;
    }
}