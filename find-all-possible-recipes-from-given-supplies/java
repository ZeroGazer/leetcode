class Solution {
    public List<String> findAllRecipes(String[] recipes, List<List<String>> ingredients, String[] supplies) {
        Map<String, List<String>> ingredientsToRecipes = new HashMap<>();
        Map<String, Integer> indegree = new HashMap<>();
        for (int i = 0; i < recipes.length; i++) {
            String recipe = recipes[i];
            indegree.put(recipe, ingredients.get(i).size());
            for (String ingredient : ingredients.get(i)) {
                if (!ingredientsToRecipes.containsKey(ingredient)) {
                    ingredientsToRecipes.put(ingredient, new ArrayList<>());
                }
                ingredientsToRecipes.get(ingredient).add(recipe);
            }
        }
        Queue<String> queue = new LinkedList<>();
        for (String supply : supplies) {
            queue.add(supply);
        }
        List<String> result = new ArrayList<>();
        while (!queue.isEmpty()) {
            String supply = queue.poll();
            if (!ingredientsToRecipes.containsKey(supply)) {
                continue;
            }

            for (String recipe : ingredientsToRecipes.get(supply)) {
                indegree.put(recipe, indegree.get(recipe) - 1);
                if (indegree.get(recipe) == 0) {
                    result.add(recipe);
                    queue.add(recipe);
                }
            }
        }
        return result;
    }
}