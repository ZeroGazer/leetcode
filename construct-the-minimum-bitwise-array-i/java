class Solution {
    public int[] minBitwiseArray(List<Integer> nums) {
        int n = nums.size();
        int[] result = new int[n];
        Arrays.fill(result, -1);
        for (int i = 0; i < n; i++) {
            int num = nums.get(i);
            for (int j = 1; j < num; j++) {
                if ((j | (j + 1)) == num) {
                    result[i] = j;
                    break;
                }
            }
        }
        return result;
    }
}