class Solution {
    public int minimumCost(int[] cost) {
        Arrays.sort(cost);
        int n = cost.length, min = 0;
        for (int i = 0; i < n; i++) {
            if (i % 3 == 2) {
                continue;
            }
            min += cost[n - 1 - i];
        }
        return min;
    }
}