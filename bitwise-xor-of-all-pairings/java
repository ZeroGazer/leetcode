class Solution {
    public int xorAllNums(int[] nums1, int[] nums2) {
        int n1 = 0, n2 = 0;
        if (nums2.length % 2 == 1) {
            for (int num1 : nums1) {
                n1 ^= num1;
            }
        }
        if (nums1.length % 2 == 1) {
            for (int num2 : nums2) {
                n2 ^= num2;
            }
        }
        return n1 ^ n2;
    }
}