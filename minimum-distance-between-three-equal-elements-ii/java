class Solution {
    public int minimumDistance(int[] nums) {
        int n = nums.length;
        Map<Integer, Integer> indexToNextIndex = new HashMap<>(), numToNextIndex = new HashMap<>();
        for (int i = n - 1; i > -1; i--) {
            if (numToNextIndex.containsKey(nums[i])) {
                indexToNextIndex.put(i, numToNextIndex.get(nums[i]));
            }
            numToNextIndex.put(nums[i], i);
        }
        int min = Integer.MAX_VALUE;
        for (Map.Entry<Integer, Integer> e : indexToNextIndex.entrySet()) {
            if (indexToNextIndex.containsKey(e.getValue())) {
                min = Math.min(min, indexToNextIndex.get(e.getValue()) - e.getKey());
            }
        }
        if (min == Integer.MAX_VALUE) {
            return -1;
        }
        return min * 2;
    }
}