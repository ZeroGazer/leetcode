class Solution {
    public int maxSum(int[] nums) {
        int n = nums.length, sum = 0, max = -100;
        boolean[] visited = new boolean[101];
        for (int i = 0; i < n; i++) {
            if (nums[i] > 0 && !visited[nums[i]]) {
                visited[nums[i]] = true;
                sum += nums[i];
            }
            max = Math.max(max, nums[i]);
        }
        if (max <= 0) {
            return max;
        }
        return sum;
    }
}