class Solution {
    public boolean hasValidPath(int[][] grid) {
        int m = grid.length, n = grid[0].length;
        boolean[][] visited = new boolean[m][n];
        return dfs(grid, visited, 0, 0, m, n);
    }

    private boolean dfs(int[][] grid, boolean[][] visited, int i, int j, int m, int n) {
        if(i == m - 1 && j == n - 1) {
            return true;
        }
        if (visited[i][j]) {
            return false;
        }
        visited[i][j] = true;
        switch (grid[i][j]) {
            case 1:
                return (j > 0 && (grid[i][j - 1] == 1 || grid[i][j - 1] == 4 || grid[i][j - 1] == 6) && dfs(grid, visited, i, j - 1, m, n)) ||
                    (j < n - 1 && (grid[i][j + 1] == 1 || grid[i][j + 1] == 3 || grid[i][j + 1] == 5) && dfs(grid, visited, i, j + 1, m, n));
            case 2:
                return (i > 0 && (grid[i - 1][j] == 2 || grid[i - 1][j] == 3 || grid[i - 1][j] == 4) && dfs(grid, visited, i - 1, j, m, n)) ||
                    (i < m - 1 && (grid[i + 1][j] == 2 || grid[i + 1][j] == 5 || grid[i + 1][j] == 6) && dfs(grid, visited, i + 1, j, m, n));
            case 3:
                return (j > 0 && (grid[i][j - 1] == 1 || grid[i][j - 1] == 4 || grid[i][j - 1] == 6) && dfs(grid, visited, i, j - 1, m, n)) ||
                    (i < m - 1 && (grid[i + 1][j] == 2 || grid[i + 1][j] == 5 || grid[i + 1][j] == 6) && dfs(grid, visited, i + 1, j, m, n));
            case 4:
                return (j < n - 1 && (grid[i][j + 1] == 1 || grid[i][j + 1] == 3 || grid[i][j + 1] == 5) && dfs(grid, visited, i, j + 1, m, n)) ||
                    (i < m - 1 && (grid[i + 1][j] == 2 || grid[i + 1][j] == 5 || grid[i + 1][j] == 6) && dfs(grid, visited, i + 1, j, m, n));
            case 5:
                return (i > 0 && (grid[i - 1][j] == 2 || grid[i - 1][j] == 3 || grid[i - 1][j] == 4) && dfs(grid, visited, i - 1, j, m, n)) ||
                    (j > 0 && (grid[i][j - 1] == 1 || grid[i][j - 1] == 4 || grid[i][j - 1] == 6) && dfs(grid, visited, i, j - 1, m, n));
            case 6:
                return (i > 0 && (grid[i - 1][j] == 2 || grid[i - 1][j] == 3 || grid[i - 1][j] == 4) && dfs(grid, visited, i - 1, j, m, n)) ||
                    (j < n - 1 && (grid[i][j + 1] == 1 || grid[i][j + 1] == 3 || grid[i][j + 1] == 5) && dfs(grid, visited, i, j + 1, m, n));
        }
        return false;
    }
}