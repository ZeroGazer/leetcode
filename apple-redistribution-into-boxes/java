class Solution {
    public int minimumBoxes(int[] apple, int[] capacity) {
        int m = capacity.length;
        Arrays.sort(capacity);
        int appleSum = 0;
        for (int a : apple) {
            appleSum += a;
        }
        for (int i = m - 1; i > -1; i--) {
            appleSum -= capacity[i];
            if (appleSum <= 0) {
                return m - i;
            }
        }
        return m;
    }
}