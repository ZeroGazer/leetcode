class Solution {
    public int countNegatives(int[][] grid) {
        int m = grid.length, n = grid[0].length, count = 0;
        for (int i = m - 1, j = 0; i > -1; i--) {
            while (j < n && grid[i][j] > -1) {
                j++;
            }
            count += n - j;
        }
        return count;
    }

}