class Solution {
    public int removeCoveredIntervals(int[][] intervals) {
        Arrays.sort(intervals, (a, b) -> Integer.compare(a[0], b[0]) != 0 ? Integer.compare(a[0], b[0]) : Integer.compare(b[1], a[1]));
        int count = 0, prevMaxEnd = 0;
        for (int[] interval : intervals) {
            if (interval[1] > prevMaxEnd) {
                count++;
                prevMaxEnd = interval[1];
            }
        }
        return count;
    }
}