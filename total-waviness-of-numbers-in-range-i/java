class Solution {
    public int totalWaviness(int num1, int num2) {
        int count = 0;
        for (int i = num1; i <= num2; i++) {
            char[] num = Integer.toString(i).toCharArray();
            for (int j = 1; j < num.length - 1; j++) {
                if ((num[j] > num[j - 1] && num[j] > num[j + 1]) || (num[j] < num[j - 1] && num[j] < num[j + 1])) {
                    count++;
                }
            }
        }
        return count;
    }
}