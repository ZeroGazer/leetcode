/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public TreeNode createBinaryTree(int[][] descriptions) {
        Map<Integer, List<int[]>> groupByParent = new HashMap<>();
        Set<Integer> parents = new HashSet<>(), children = new HashSet<>();
        for (int[] description : descriptions) {
            groupByParent.computeIfAbsent(description[0], k -> new ArrayList<>()).add(description);
            parents.add(description[0]);
            parents.add(description[1]);
            children.add(description[1]);
        }
        parents.removeAll(children);
        TreeNode root = new TreeNode(parents.iterator().next());
        Queue<TreeNode> queue = new LinkedList<>();
        queue.offer(root);
        while (!queue.isEmpty()) {
            TreeNode curr = queue.poll();
            if (groupByParent.containsKey(curr.val)) {
                for (int[] description : groupByParent.get(curr.val)) {
                    TreeNode child = new TreeNode(description[1]);
                    if (description[2] == 1) {
                        curr.left = child;
                    } else {
                        curr.right = child;
                    }
                    queue.offer(child);
                }
            }
        }
        return root;
    }
}