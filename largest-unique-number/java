class Solution {
    public int largestUniqueNumber(int[] nums) {
        int[] freqs = new int[1001];
        for (int i : nums) {
            freqs[i]++;
        }
        int max = -1;
        for (int i = 0; i < freqs.length; i++) {
            if (freqs[i] == 1) {
                max = i;
            }
        }
        return max;
    }
}