class Solution {
    public int subsetXORSum(int[] nums) {
        return backtracking(nums, 0, 0);
    }

    private int backtracking(int[] nums, int i, int curr) {
        if (i == nums.length) {
            return curr;
        }
        return backtracking(nums, i + 1, curr) + backtracking(nums, i + 1, curr ^ nums[i]);
    }
}