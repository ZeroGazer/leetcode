class Solution {
    public int minimizeXor(int num1, int num2) {
        int bits = Integer.bitCount(num2), result = 0;
        for (int curr = 31, count = 0; count < bits; curr--) {
            if ((num1 & (1 << curr)) != 0 || bits - count > curr) {
                result |= (1 << curr);
                count++;
            }
        }
        return result;
    }
}