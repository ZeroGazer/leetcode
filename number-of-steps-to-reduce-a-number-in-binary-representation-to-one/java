class Solution {
    public int numSteps(String s) {
        int n = s.length(), steps = 0, carry = 0;
        for (int i = n - 1; i > 0; i--) {
            int last = Character.getNumericValue(s.charAt(i)) + carry;
            if ((last & 1) == 1) {
                carry = 1;
                steps += 2;
            } else {
                steps++;
            }
        }
        return carry + steps;
    }
}