class Solution {
    public long sumAndMultiply(int n) {
        long x = 0, sum = 0, power = 1;
        while (n > 0) {
            int digit = n % 10;
            n /= 10;
            if (digit > 0) {
                sum += digit;
                x += digit * power;
                power *= 10;
            }
        }
        return x * sum;
    }
}