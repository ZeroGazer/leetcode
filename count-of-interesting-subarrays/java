class Solution {
    public long countInterestingSubarrays(List<Integer> nums, int modulo, int k) {
        int sum = 0;
        long count = 0;
        Map<Integer, Integer> partial = new HashMap<>();
        partial.put(0, 1);
        for (int num : nums) {
            sum += num % modulo == k ? 1 : 0;
            count += partial.getOrDefault((sum - k + modulo) % modulo, 0);
            partial.put(sum % modulo, partial.getOrDefault(sum % modulo, 0) + 1);
        }
        return count;
    }
}