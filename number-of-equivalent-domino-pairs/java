class Solution {
    public int numEquivDominoPairs(int[][] dominoes) {
        int[] freqs = new int[100];
        int count = 0;
        for (int[] domino : dominoes) {
            Arrays.sort(domino);
            int key = domino[0] * 10 + domino[1];
            count += freqs[key]++;
        }
        return count;
    }
}