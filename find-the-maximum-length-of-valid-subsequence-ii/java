class Solution {
    public int maximumLength(int[] nums, int k) {
        int[][] dp = new int[k][k];
        int max = 0;
        for (int num : nums) {
            num %= k;
            for (int i = 0; i < k; i++) {
                dp[num][i] = dp[i][num] + 1;
                max = Math.max(max, dp[num][i]);
            }
        }
        return max;
    }
}