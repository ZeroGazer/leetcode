class Solution {
    public int removeDuplicates(int[] nums) {
        int n = nums.length, k = 1, prev = nums[0];
        for (int left = 1, right = 1; right < n; right++) {
            if (nums[right] != prev) {
                prev = nums[right];
                nums[left++] = nums[right];
                k++;
            }
        }
        return k;
    }
}