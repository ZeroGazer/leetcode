class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int[] result = new int[n];
        for (int i = 1; i < n; i++) {
            result[i] = result[i - 1] + nums[i - 1];
        }
        for (int i = n - 1, sum = 0; i > -1; i--) {
            result[i] = Math.abs(result[i] - sum);
            sum += nums[i];
        }
        return result;
    }
}