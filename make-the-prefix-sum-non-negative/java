class Solution {
    public int makePrefSumNonNegative(int[] nums) {
        int count = 0;
        long sum = 0;
        Queue<Integer> queue = new PriorityQueue<>();
        for (int num : nums) {
            if (num < 0) {
                queue.offer(num);
            }
            sum += num;
            while (sum < 0) {
                sum -= queue.poll();
                count++;
            }
        }
        return count;
    }
}