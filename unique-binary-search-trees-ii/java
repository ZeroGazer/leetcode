/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public List<TreeNode> generateTrees(int n) {
        return generateTrees(1, n, new HashMap<>());
    }

    private List<TreeNode> generateTrees(int start, int end, Map<Pair<Integer, Integer>, List<TreeNode>> memo) {
        List<TreeNode> result = new ArrayList<>();
        if (start > end) {
            result.add(null);
            return result;
        }
        Pair<Integer, Integer> key = new Pair<>(start, end);
        if (memo.containsKey(key)) {
            return memo.get(key);
        }
        for (int i = start; i <= end; i++) {
            List<TreeNode> left = generateTrees(start, i - 1, memo), right = generateTrees(i + 1, end, memo);
            for (TreeNode l : left) {
                for (TreeNode r : right) {
                    result.add(new TreeNode(i, l, r));
                }
            }
        }
        memo.put(key, result);
        return result;
    }
}