class Solution {
    public int numOfUnplacedFruits(int[] fruits, int[] baskets) {
        int n = fruits.length;
        int m = (int) Math.sqrt(n);
        int blocks = Math.ceilDiv(n, m);
        int[] maxBlocks = new int[blocks];
        for (int i = 0; i < n; i++) {
            maxBlocks[i / m] = Math.max(maxBlocks[i / m], baskets[i]);
        }
        int count = n;
        for (int fruit : fruits) {
            for (int i = 0; i < blocks; i++) {
                if (maxBlocks[i] < fruit) {
                    continue;
                }
                boolean isChosen = false;
                maxBlocks[i] = 0;
                for (int j = 0; j < m; j++) {
                    int basketIndex = i * m + j;
                    if (basketIndex >= n) {
                        break;
                    }
                    if (!isChosen && baskets[basketIndex] >= fruit) {
                        isChosen = true;
                        baskets[basketIndex] = 0;
                        count--;
                    }
                    maxBlocks[i] = Math.max(maxBlocks[i], baskets[basketIndex]);
                }
                break;
            }
        }
        return count;
    }
}