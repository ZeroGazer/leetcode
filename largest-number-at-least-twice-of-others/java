class Solution {
    public int dominantIndex(int[] nums) {
        int max = 0, max2 = 0;
        int index = -1;
        for (int i = 0; i < nums.length; i++) {
            int num = nums[i];
            if (num >= max) {
                max2 = max;
                max = num;
                index = i;
            } else if (num > max2) {
                max2 = num;
            } 
        }
        if (max >= max2 * 2) {
            return index;
        }
        return -1;
    }
}