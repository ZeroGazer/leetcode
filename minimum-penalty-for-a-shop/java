class Solution {
    public int bestClosingTime(String customers) {
        int hour = 0;
        for (int i = 0, min = 0, curr = 0; i < customers.length(); i++) {
            if (customers.charAt(i) == 'Y') {
                curr--;
            } else {
                curr++;
            }
            if (curr < min) {
                curr = min;
                hour = i + 1;
            }
        }
        return hour;
    }
}