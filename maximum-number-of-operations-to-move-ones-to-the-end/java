class Solution {
    public int maxOperations(String s) {
        int op = 0;
        for (int i = 0, left1 = 0; i < s.length(); i++) {
            if (s.charAt(i) == '0') {
                while (i + 1 < s.length() && s.charAt(i + 1) == '0') {
                    i++;
                }
                op += left1;
            } else {
                left1++;
            }
        }
        return op;
    }
}