class Solution {
    public int maxRotateFunction(int[] nums) {
        int n = nums.length, sum = 0, f = 0;
        for (int i = 0; i < n; i++) {
            sum += nums[i];
            f += i * nums[i];
        }
        int max = f;
        for (int i = 1; i < n; i++) {
            f += sum - n * nums[n - i];
            max = Math.max(max, f);
        }
        return max;
    }
}