class Solution {
    public List<Integer> replaceNonCoprimes(int[] nums) {
        Stack<Integer> stack = new Stack<>();
        for (int num : nums) {
            while (!stack.isEmpty()) {
                int gcd = getGcd(stack.peek(), num);
                if (gcd > 1) {
                    num = getLcm(stack.pop(), num, gcd);
                } else {
                    break;
                }
            }
            stack.push(num);
        }
        return new ArrayList<>(stack);
    }

    private int getGcd(int a, int b) {
        if (b == 0) {
            return a;
        }
        return getGcd(b, a % b);
    }

    private int getLcm(int a, int b, int gcd) {
        return a / gcd * b;
    }
}