class Solution {
    public String[] divideString(String s, int k, char fill) {
        int n = s.length();
        List<String> result = new ArrayList<>();
        for (int i = 0; i < n; i += k) {
            result.add(s.substring(i, Math.min(i + k, n)));
        }
        String lastString = result.getLast();
        if (lastString.length() < k) {
            StringBuilder sb = new StringBuilder(lastString);
            sb.repeat(fill, k - lastString.length());
            result.set(result.size() - 1, sb.toString());
        }
        return result.toArray(new String[0]);
    }
}