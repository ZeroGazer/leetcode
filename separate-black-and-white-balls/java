class Solution {
    public long minimumSteps(String s) {
        long count1 = 0;
        for (char c : s.toCharArray()) {
            if (c == '1') {
                count1++;
            }
        }
        long index = s.length() - count1;
        long steps = 0;
        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '1') {
                steps += index++ - i;
            }
        }
        return steps;
    }
}