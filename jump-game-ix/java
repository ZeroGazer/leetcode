class Solution {
    public int[] maxValue(int[] nums) {
        int n = nums.length;
        int[] result = new int[n];
        result[0] = nums[0];
        for (int i = 1; i < n; i++) {
            result[i] = Math.max(result[i - 1], nums[i]);
        }
        for (int i = n - 2, min = nums[n - 1]; i > -1; i--) {
            if (result[i] > min) {
                result[i] = result[i + 1];
            }
            min = Math.min(min, nums[i]);
        }
        return result;
    }
}