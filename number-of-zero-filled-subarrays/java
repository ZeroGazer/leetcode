class Solution {
    public long zeroFilledSubarray(int[] nums) {
        int n = nums.length;
        long count = 0, curr = 0;
        for (int i = 0; i < n; i++) {
            if (nums[i] == 0) {
                curr++;
                count += curr;
            } else {
                curr = 0;
            }
        }
        return count;
    }
}