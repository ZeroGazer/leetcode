class Solution {
    public String[] spellchecker(String[] wordlist, String[] queries) {
        Set<String> words = new HashSet<>();
        Map<String, String> lowercaseWords = new HashMap<>();
        Map<String, String> devowelWords = new HashMap<>();
        for (String word : wordlist) {
            words.add(word);
            String lowercaseWord = word.toLowerCase();
            lowercaseWords.putIfAbsent(lowercaseWord, word);
            devowelWords.putIfAbsent(lowercaseWord.replaceAll("[aeiou]", "*"), word);
        }
        String[] results = new String[queries.length];
        for (int i = 0; i < results.length; i++) {
            String query = queries[i];
            String result = "";
            if (words.contains(query)) {
                result = query;
            } else {
                String lowercaseQuery = query.toLowerCase();
                if (lowercaseWords.containsKey(lowercaseQuery)) {
                    result = lowercaseWords.get(lowercaseQuery);
                } else {
                    String devowelQuery = lowercaseQuery.replaceAll("[aeiou]", "*");
                    if (devowelWords.containsKey(devowelQuery)) {
                        result = devowelWords.get(devowelQuery);
                    }
                }
            }
            results[i] = result;
        }
        return results;
    }
}