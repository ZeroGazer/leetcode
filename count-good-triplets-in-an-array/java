class Solution {
    public long goodTriplets(int[] nums1, int[] nums2) {
        int n = nums1.length;
        int[] nums2ToNums2Index = new int[n];
        for (int i = 0; i < n; i++) {
            nums2ToNums2Index[nums2[i]] = i;
        }
        int[] nums2IndexToNums1Index = new int[n];
        for (int i = 0; i < n; i++) {
            nums2IndexToNums1Index[nums2ToNums2Index[nums1[i]]] = i;
        }
        FenwickTree tree = new FenwickTree(n);
        long count = 0;
        for (int i = 0; i < n; i++) {
            int index = nums2IndexToNums1Index[i];
            int left = tree.query(index + 1);
            tree.update(index + 1, 1);
            int right = (n - 1 - index) - (i - left);
            count += (long) left * right;
        }
        return count;
    }
}

class FenwickTree {
    private int[] tree;

    public FenwickTree(int size) {
        tree = new int[size + 1];
    }

    public void update(int index, int delta) {
        while (index < tree.length) {
            tree[index] += delta;
            index += index & -index;
        }
    }

    public int query(int index) {
        int sum = 0;
        while (index > 0) {
            sum += tree[index];
            index -= index & -index;
        }
        return sum;
    }
}
