class Solution {
    public int numberOfAlternatingGroups(int[] colors, int k) {
        int n = colors.length, count = 0;
        for (int left = 0, right = 1; right < n + k - 1; right++) {
            if (colors[right % n] == colors[(right + n - 1) % n]) {
                left = right;
            }
            if (right - left + 1 >= k) {
                count++;
            }
        }
        return count;
    }
}