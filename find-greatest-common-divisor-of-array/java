class Solution {
    public int findGCD(int[] nums) {
        int min = Integer.MAX_VALUE, max = Integer.MIN_VALUE;
        for (int num : nums) {
            min = Math.min(min, num);
            max = Math.max(max, num);
        }

        while (min != 0) {
            int tmp = max;
            max = min;
            min = tmp % min;
        }
        return max;
    }
}