class Solution {
    public int maxProfit(int[] prices) {
        int n = prices.length, prevBuy = Integer.MIN_VALUE, buy = Integer.MIN_VALUE, prevSell = 0, sell = 0;
        for (int i = 0; i < n; i++) {
            prevBuy = buy;
            buy = Math.max(prevSell - prices[i], buy);
            prevSell = sell;
            sell = Math.max(prevBuy + prices[i], sell);
        }
        return sell;
    }
}