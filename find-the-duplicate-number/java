class Solution {
    public int findDuplicate(int[] nums) {
        int n = nums.length - 1;
        int left = 1, right = n;
        while (left < right) {
            int middle = left + (right - left) / 2;
            if (count(nums, middle) > middle) {
                right = middle;
            } else {
                left = middle + 1;
            }
        }
        return left;
    }

    private int count(int[] nums, int x) {
        int count = 0;
        for (int num : nums) {
            if (num <= x) {
                count++;
            }
        }
        return count;
    }
}