class Solution {
    public int minimumSize(int[] nums, int maxOperations) {
        int left = 1, right = Arrays.stream(nums).max().getAsInt();
        while (left < right) {
            int middle = left + (right - left) / 2;
            if (validate(nums, maxOperations, middle)) {
                right = middle;
            } else {
                left = middle + 1;
            }
        }
        return left;
    }

    private boolean validate(int[] nums, int maxOperations, int max) {
        for (int num : nums) {
            maxOperations -= Math.ceilDiv(num, max) - 1;
            if (maxOperations < 0) {
                return false;
            }
        }
        return true;
    }
}