class FindSumPairs {

    private int[] nums1;
    private int[] nums2;
    private Map<Integer, Integer> freqs2 = new HashMap<>();

    public FindSumPairs(int[] nums1, int[] nums2) {
        this.nums1 = nums1;
        this.nums2 = nums2;
        for (int num2 : nums2) {
            freqs2.put(num2, freqs2.getOrDefault(num2, 0) + 1);
        }
    }
    
    public void add(int index, int val) {
        freqs2.put(nums2[index], freqs2.get(nums2[index]) - 1);
        nums2[index] += val;
        freqs2.put(nums2[index], freqs2.getOrDefault(nums2[index], 0) + 1);
    }
    
    public int count(int tot) {
        int count = 0;
        for (int num1 : nums1) {
            count += freqs2.getOrDefault(tot - num1, 0);
        }
        return count;
    }
}

