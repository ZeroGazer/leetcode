class NumberContainers {

    private Map<Integer, TreeSet<Integer>> nums = new HashMap<>();
    private Map<Integer, Integer> indexes = new HashMap<>();

    public NumberContainers() {
        
    }
    
    public void change(int index, int number) {
        if (indexes.containsKey(index)) {
            nums.get(indexes.get(index)).remove(index);
            if (nums.get(indexes.get(index)).isEmpty()) {
                nums.remove(indexes.get(index));
            }
        }
        if (!nums.containsKey(number)) {
            nums.put(number, new TreeSet<>());
        }
        nums.get(number).add(index);
        indexes.put(index, number);
    }
    
    public int find(int number) {
        if (!nums.containsKey(number)) {
            return -1;
        }
        return nums.get(number).first();
    }
}

