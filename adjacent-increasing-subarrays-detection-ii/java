class Solution {
    public int maxIncreasingSubarrays(List<Integer> nums) {
        int prevInc = 0, currInc = 1, maxK = 0;
        for (int i = 1; i < nums.size(); i++) {
            if (nums.get(i) > nums.get(i - 1)) {
                currInc++;
            } else {
                prevInc = currInc;
                currInc = 1;
            }
            maxK = Math.max(maxK, Math.max(currInc / 2, Math.min(prevInc, currInc)));
        }
        return maxK;
    }
}