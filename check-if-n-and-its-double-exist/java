class Solution {
    public boolean checkIfExist(int[] arr) {
        Set<Integer> s1 = new HashSet<>(), s2 = new HashSet<>();
        for (int n : arr) {
            if (s1.contains(n * 2) || s2.contains(n)) {
                return true;
            }
            s1.add(n);
            s2.add(n * 2);
        }
        return false;
    }
}