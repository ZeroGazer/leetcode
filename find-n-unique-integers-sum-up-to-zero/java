class Solution {
    public int[] sumZero(int n) {
        int[] result = new int[n];
        for (int i = 0; i < n / 2; i++) {
            result[i * 2] = i + 1;
            result[i * 2 + 1] = - i - 1;
        }
        if ((n & 1) == 1) {
            result[n - 1] = 0;
        }
        return result;
    }
}
