class Solution {
    public long countBadPairs(int[] nums) {
        Map<Integer, Integer> freqs = new HashMap<>();
        long badPairs = 0;
        for (int i = 0; i < nums.length; i++) {
            int goodPairs = freqs.getOrDefault(nums[i] - i, 0);
            badPairs += i - goodPairs;
            freqs.put(nums[i] - i, goodPairs + 1);
        }
        return badPairs;
    }
}