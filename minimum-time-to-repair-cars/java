class Solution {
    public long repairCars(int[] ranks, int cars) {
        int minRank = Arrays.stream(ranks).min().getAsInt();
        long left = 1, right = 1L * minRank * cars * cars;
        while (left < right) {
            long middle = left + (right - left) / 2;
            if (!canRepair(ranks, cars, middle)) {
                left = middle + 1;
            } else {
                right = middle;
            }
        }
        return left;
    }

    private boolean canRepair(int[] ranks, int cars, double time) {
        long repaired = 0;
        for (int rank : ranks) {
            repaired += Math.sqrt(time / rank);
        }
        return repaired >= cars;
    }
}