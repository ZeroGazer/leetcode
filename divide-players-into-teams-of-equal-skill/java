class Solution {
    public long dividePlayers(int[] skill) {
        Arrays.sort(skill);
        int kill = skill[0] + skill[skill.length - 1];
        long chemistry = 0;
        for (int i = 0; i < skill.length / 2; i++) {
            if (kill != (skill[i] + skill[skill.length - 1 - i])) {
                return -1;
            }
            chemistry += skill[i] * skill[skill.length - 1 - i];
        }
        return chemistry;
    }
}