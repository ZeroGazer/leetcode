class Solution {
    public int maxAscendingSum(int[] nums) {
        int max = nums[0], count = nums[0];
        for (int i = 1; i < nums.length; i++) {
            if (nums[i] > nums[i - 1]) {
                count += nums[i];
            } else {
                count = nums[i];
            }
            max = Math.max(max, count);
        }
        return max;
    }
}