class Solution {
    public int maximumLength(int[] nums) {
        int odd = 0, even = 0, alternating = 0;
        boolean wasEven = (nums[0] & 1) == 1;
        for (int i : nums) {
            if ((i & 1) == 1) {
                odd++;
                if (wasEven) {
                    wasEven = !wasEven;
                    alternating++;
                }
            } else {
                even++;
                if (!wasEven) {
                    wasEven = !wasEven;
                    alternating++;
                }
            }
        }
        return Math.max(Math.max(odd, even), alternating);
    }
}