class Solution {
    private static final int MOD = (int) 1e9 + 7;

    public int numOfWays(int n) {
        long aba = 6, abc = 6;
        while (n-- > 1) {
            long nextAba = (aba * 3 + abc * 2) % MOD, nextAbc = (aba * 2 + abc * 2) % MOD;
            aba = nextAba;
            abc = nextAbc;
        }
        return (int) ((aba + abc) % MOD);
    }
}
