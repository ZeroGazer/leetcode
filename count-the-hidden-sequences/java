class Solution {
    public int numberOfArrays(int[] differences, int lower, int upper) {
        long curr = 0, min = 0, max = 0;
        for (int diff : differences) {
            curr += diff;
            min = Math.min(min, curr);
            max = Math.max(max, curr);
        }
        long shift = upper - max;
        min += shift;
        if (min < lower) {
            return 0;
        }
        return (int) min - lower + 1;
    }
}