class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int n = A.length;
        int[] result = new int[n], prev = new int[n + 1];
        for (int i = 0, count = 0; i < n; i++) {
            if (++prev[A[i]] == 2) {
                count++;
            }
            if (++prev[B[i]] == 2) {
                count++;;
            }
            result[i] = count;
        }
        return result;
    }
}