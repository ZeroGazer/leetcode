class Solution {
    public int maximumUniqueSubarray(int[] nums) {
        int sum = 0, maxSum = 0;
        Set<Integer> set = new HashSet<>();
        for (int left = 0, right = 0; right < nums.length; right++) {
            while (set.contains(nums[right])) {
                set.remove(nums[left]);
                sum -= nums[left++];
            }
            set.add(nums[right]);
            sum += nums[right];
            maxSum = Math.max(maxSum, sum);
        }
        return maxSum;
    }
}