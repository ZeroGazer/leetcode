class Solution {
    public long mostPoints(int[][] questions) {
        int n = questions.length;
        long[] dp = new long[n + 1];
        for (int i = n - 1; i > -1; i--) {
            int[] question = questions[i];
            dp[i] = question[0];
            if (i + question[1] + 1 < n) {
                dp[i] = Math.max(dp[i], question[0] + dp[i + question[1] + 1]);
            }
            dp[i] = Math.max(dp[i], dp[i + 1]);
        }
        return dp[0];
    }
}