class Solution {
    public long maxKelements(int[] nums, int k) {
        Queue<Integer> pq = new PriorityQueue<>(Comparator.reverseOrder());
        for (int num : nums) {
            pq.add(num);
        }
        long result = 0;
        for (int i = 0; i < k; i++) {
            result += pq.peek();
            pq.offer(Math.ceilDiv(pq.poll(), 3));
        }
        return result;
    }
}