class Solution {
    public int minimumHammingDistance(int[] source, int[] target, int[][] allowedSwaps) {
        int n = source.length;
        UnionFind uf = new UnionFind(n);
        for (int[] allowedSwap : allowedSwaps) {
            uf.union(allowedSwap[0], allowedSwap[1]);
        }
        Map<Integer, List<Integer>> groupsByRoot = new HashMap<>();
        for (int i = 0; i < n; i++) {
            groupsByRoot.computeIfAbsent(uf.find(i), k -> new ArrayList<>()).add(i);
        }
        int distance = 0;
        for (List<Integer> groups : groupsByRoot.values()) {
            Map<Integer, Integer> freqs = new HashMap<>();
            for (int index : groups) {
                freqs.put(source[index], freqs.getOrDefault(source[index], 0) + 1);
            }
            for (int index : groups) {
                int value = target[index];
                if (freqs.getOrDefault(value, 0) > 0) {
                    freqs.put(value, freqs.get(value) - 1);
                } else {
                    distance++;
                }
            }
        }
        return distance;
    }
}

class UnionFind {
    private int[] root;
    private int[] rank;

    public UnionFind(int n) {
        root = new int[n];
        rank = new int[n];
        for (int i = 0; i < n; i++) {
            root[i] = i;
        }
    }

    public int find(int a) {
        if (root[a] != a) {
            root[a] = find(root[a]);
        }
        return root[a];
    }

    public void union(int a, int b) {
        int rootA = find(a), rootB = find(b);
        if (rootA == rootB) {
            return;
        }
        if (rank[rootA] > rank[rootB]) {
            root[rootB] = rootA;
        } else if (rank[rootB] < rank[rootB]) {
            root[rootA] = rootB;
        } else {
            root[rootB] = rootA;
            rank[rootA]++;
        }
    }
}