class Solution {
    public int largestUniqueNumber(int[] nums) {
        int[] freqs = new int[1001];
        for (int i : nums) {
            freqs[i]++;
        }
        for (int i = 1000; i > -1; i--) {
            if (freqs[i] == 1) {
                return i;
            }
        }
        return -1;
    }
}