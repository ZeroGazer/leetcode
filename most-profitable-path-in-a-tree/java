class Solution {
    private int maxIncome = Integer.MIN_VALUE;
    public int mostProfitablePath(int[][] edges, int bob, int[] amount) {
        int n = amount.length;
        Map<Integer, List<Integer>> paths = new HashMap<>();
        for (int i = 0; i < n; i++) {
            paths.put(i, new ArrayList<>());
        }
        for (int[] edge : edges) {
            paths.get(edge[0]).add(edge[1]);
            paths.get(edge[1]).add(edge[0]);
        }
        boolean[] visited = new boolean[n];
        int[] bobVisitedTime = new int[n];
        Arrays.fill(bobVisitedTime, -1);
        findBobPath(paths, bob, visited, bobVisitedTime, 0);
        
        Arrays.fill(visited, false);
        findAlicePath(paths, 0, visited, 0, amount, 0, bobVisitedTime);
        return maxIncome;
    }

    public boolean findBobPath(Map<Integer, List<Integer>> paths, int node, boolean[] visited, int[] visitedTime, int time) {
        visited[node] = true;
        visitedTime[node] = time;
        if (node == 0) {
            return true;
        }
        for (int neighbour : paths.get(node)) {
            if (!visited[neighbour] && findBobPath(paths, neighbour, visited, visitedTime, time + 1)) {
                return true;
            }
        }
        visitedTime[node] = -1;
        return false;
    }

    public void findAlicePath(Map<Integer, List<Integer>> paths, int node, boolean[] visited, int time, int[] amount, int income, int[] bobVisitedTime) {
        visited[node] = true;
        if (bobVisitedTime[node] == -1 || time < bobVisitedTime[node]) {
            income += amount[node];
        } else if (time == bobVisitedTime[node]) {
            income += amount[node] / 2;
        }
        if (node != 0 && paths.get(node).size() == 1) {
            maxIncome = Math.max(maxIncome, income);
        }
        for (int neighbour : paths.get(node)) {
            if (!visited[neighbour]) {
                findAlicePath(paths, neighbour, visited, time + 1, amount, income, bobVisitedTime);
            }
        }
    }
}