class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int underscore = 0, left = 0, right = 0;
        for (char c : moves.toCharArray()) {
            if (c == '_') {
                underscore++;
            } else if (c == 'L') {
                left++;
            } else if (c == 'R') {
                right++;
            }
        }
        return underscore + Math.abs(left - right);
    }
}