class Solution {
    public int longestSubarray(int[] nums) {
        int n = nums.length, max = 0;
        for (int left = 0, right = 0, count0 = 0; right < n; right++) {
            if (nums[right] == 0 && ++count0 == 2) {
                while (count0 == 2) {
                    count0 -= 1 - nums[left++];
                }
            } else {
                max = Math.max(max, right - left);
            }
        }
        return max;
    }
}